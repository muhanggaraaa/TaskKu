# Dependencies (install with npm ci in CI/production)
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output and caches
/.next/
/out/
/build/
.turbo/

# Test/coverage output
/coverage/

# Environment and deployment-local files
.env
.env.*
!.env.example
.vercel/

# TypeScript / generated files
*.tsbuildinfo
next-env.d.ts

# Logs and debug artifacts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Coursework/source-material folders that are not needed by production deploy
/Tugas*/

# Large local evidence/source-material files (keep production assets under /public if needed)
**/Cuplikan layar*
**/*.pdf

# AI agent config files (local assistant context only)
AGENTS.md
CLAUDE.md
.gemini/
.codex/
.devin/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS / misc
.DS_Store
Thumbs.db
*.pem
